{
  "name": "czl-invoice-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "CZL 发票 - 本地发票生成器 (by CZL Express)",
  "author": "CZL Express",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "net.czl.invoice",
    "productName": "CZL 发票",
    "forceCodeSigning": false,
    "directories": {
      "output": "../dist-desktop",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../.next/standalone",
        "to": "app"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "dir"
        }
      ]
    }
  }
}
