{
  "name": "czl-invoice-desktop",
  "version": "0.1.1",
  "private": true,
  "description": "CZL 发票 - 本地发票生成器 (by CZL Express)",
  "author": "CZL Express",
  "main": "main.js",
  "scripts": {
    "start": "cross-env ELECTRON_RUN_AS_NODE= electron .",
    "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --publish never"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "net.czl.invoice",
    "productName": "CZL 发票",
    "forceCodeSigning": false,
    "directories": {
      "output": "../dist-desktop",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../.next/standalone",
        "to": "app"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CZL 发票",
      "artifactName": "CZL-Invoice-Setup-${version}.exe"
    }
  }
}
